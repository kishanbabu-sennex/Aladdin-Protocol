use tokio::net::{TcpListener, TcpStream};
use tokio::io::{AsyncReadExt, AsyncWriteExt};
use std::error::Error;
use std::time::Instant;

// Hardcoded configuration for Nano-second / Micro-second benchmarking
const NODE_ADDRESS: &str = "127.0.0.1:8080";
const BUFFER_SIZE: usize = 1024;

#[tokio::main]
async fn main() -> Result<(), Box<dyn Error>> {
    println!("[SENNEX NODE] Initializing Phase 1 Core Protocol on {}...", NODE_ADDRESS);

    // Start the ultra-low latency listener node
    let listener = TcpListener::bind(NODE_ADDRESS).await?;
    println!("[SENNEX NODE] Network Live. Awaiting incoming data streams...");

    loop {
        let (socket, addr) = listener.accept().await?;
        // Process each incoming connection in a lightweight, non-blocking asynchronous task
        tokio::spawn(async move {
            println!("[SENNEX] Connection established with peer: {}", addr);
            if let Err(e) = handle_peer_stream(socket).await {
                eprintln!("[SENNEX ERROR] Stream processing failed: {}", e);
            }
        });
    }
}

// In-Memory processing function bypassing disk I/O for speed
async fn handle_peer_stream(mut socket: TcpStream) -> Result<(), Box<dyn Error>> {
    let mut buffer = [0; BUFFER_SIZE];

    loop {
        let start_time = Instant::now();
        let bytes_read = socket.read(&mut buffer).await?;

        if bytes_read == 0 {
            break; // Stream completed by peer
        }

        // Processing latency benchmark
        let duration = start_time.elapsed();
        println!(
            "[SENNEX] Raw packet processed in memory. Size: {} bytes | Latency: {:?}",
            bytes_read, duration
        );

        // Echoing back zero-copy acknowledgement immediately to peer
        socket.write_all(&buffer[..bytes_read]).await?;
    }
    Ok(())
}
// Save this as a new module or append to your existing main.rs file
use std::convert::TryInto;
use std::time::Instant;

// System Constants for Hardware Optimization
const MAGIC_BYTES: &[u8; 4] = b"SNX1"; // Unique identifier for SENNEX Phase 1 Protocol
const HEADER_SIZE: usize = 12;         // Magic (4B) + Packet ID (4B) + Payload Length (4B)
const MAX_PAYLOAD: usize = 1012;       // Forces total packet size to exactly 1024 bytes (1KB alignment)

#[derive(Debug)]
pub struct SennexPacket {
    pub packet_id: u32,
    pub payload_len: u32,
    pub payload: Vec<u8>,
}

impl SennexPacket {
    /// Zero-copy evaluation of raw incoming network byte streams
    pub fn parse_raw_stream(buffer: &[u8]) -> Result<Self, &'static str> {
        if buffer.len() < HEADER_SIZE {
            return Err("ERR_INSUFFICIENT_DATA: Packet header incomplete.");
        }

        // 1. Verify Protocol Signature (Zero Latency Boundary)
        if &buffer[0..4] != MAGIC_BYTES {
            return Err("ERR_PROTOCOL_MISMATCH: Unauthorized packet signature detected.");
        }

        // 2. Extract Header Metadata directly using bitwise boundary slices
        let packet_id = u32::from_be_bytes(buffer[4..8].try_into().unwrap());
        let payload_len = u32::from_be_bytes(buffer[8..12].try_into().unwrap()) as usize;

        if payload_len > MAX_PAYLOAD {
            return Err("ERR_PAYLOAD_OVERFLOW: Packet size exceeds maximum 1024 byte hardware alignment.");
        }

        if buffer.len() < HEADER_SIZE + payload_len {
            return Err("ERR_CORRUPTED_STREAM: Actual byte length does not match header declaration.");
        }

        // 3. Extract payload slice without reallocation
        let payload = buffer[HEADER_SIZE..HEADER_SIZE + payload_len].to_vec();

        Ok(SennexPacket {
            packet_id,
            payload_len: payload_len as u32,
            payload,
        })
    }
}

// Low-Latency Verification Benchmarking Engine
pub fn benchmark_packet_parsing() {
    // Simulated incoming binary stream from a remote network node
    let mut mock_stream = Vec::new();
    mock_stream.extend_from_slice(MAGIC_BYTES);                 // Bytes 0-3: Magic Header
    mock_stream.extend_from_slice(&1005u32.to_be_bytes());       // Bytes 4-7: Packet ID 1005
    mock_stream.extend_from_slice(&14u32.to_be_bytes());         // Bytes 8-11: Payload Length 14
    mock_stream.extend_from_slice(b"ALADDIN_DATA_01");          // Bytes 12+: Raw System Payload

    let start = Instant::now();
    
    match SennexPacket::parse_raw_stream(&mock_stream) {
        Ok(packet) => {
            let duration = start.elapsed();
            println!("[SENNEX ENGINE] Packet parsed successfully.");
            println!("[SENNEX ENGINE] ID: {} | Size: {} bytes | Execution Overhead: {:?}", packet.packet_id, packet.payload_len, duration);
        }
        Err(e) => println!("[SENNEX ENGINE] Validation Failure: {}", e),
    }
}
use tokio::net::{TcpListener, TcpStream};
use tokio::io::{AsyncReadExt, AsyncWriteExt};
use std::error::Error;
use std::time::Instant;
use std::convert::TryInto;

// ---- 1. System Configuration and Constants ----
const NODE_ADDRESS: &str = "127.0.0.1:8080";
const BUFFER_SIZE: usize = 1024;
const MAGIC_BYTES: &[u8; 4] = b"SNX1"; 
const HEADER_SIZE: usize = 12;         
const MAX_PAYLOAD: usize = 1012;       

// ---- 2. Low-Latency Packet Structure ----
#[derive(Debug)]
pub struct SennexPacket {
    pub packet_id: u32,
    pub payload_len: u32,
    pub payload: Vec<u8>,
}

impl SennexPacket {
    pub fn parse_raw_stream(buffer: &[u8]) -> Result<Self, &'static str> {
        if buffer.len() < HEADER_SIZE {
            return Err("ERR_INSUFFICIENT_DATA");
        }
        if &buffer[0..4] != MAGIC_BYTES {
            return Err("ERR_PROTOCOL_MISMATCH");
        }
        let packet_id = u32::from_be_bytes(buffer[4..8].try_into().unwrap());
        let payload_len = u32::from_be_bytes(buffer[8..12].try_into().unwrap()) as usize;

        if payload_len > MAX_PAYLOAD || buffer.len() < HEADER_SIZE + payload_len {
            return Err("ERR_CORRUPTED_STREAM");
        }

        let payload = buffer[HEADER_SIZE..HEADER_SIZE + payload_len].to_vec();
        Ok(SennexPacket {
            packet_id,
            payload_len: payload_len as u32,
            payload,
        })
    }
}

// ---- 3. Dual-Mode Execution Framework ----
#[tokio::main]
async fn main() -> Result<(), Box<dyn Error>> {
    // Check command line arguments to run either Simulation or Live Node
    let args: Vec<String> = std::env::args().collect();
    
    if args.contains(&"--simulate".to_string()) {
        println!("[SENNEX SIMULATION] Launching Local Multi-Node Cluster Test...");
        run_local_simulation().await?;
        return Ok(());
    }

    println!("[SENNEX NODE] Initializing Phase 1 Live Protocol on {}...", NODE_ADDRESS);
    let listener = TcpListener::bind(NODE_ADDRESS).await?;
    println!("[SENNEX NODE] Network Live. Awaiting incoming data streams...");

    loop {
        let (socket, addr) = listener.accept().await?;
        tokio::spawn(async move {
            if let Err(e) = handle_peer_stream(socket).await {
                eprintln!("[SENNEX ERROR] Stream failure: {}", e);
            }
        });
    }
}

// ---- 4. In-Memory Processing & Verification ----
async fn handle_peer_stream(mut socket: TcpStream) -> Result<(), Box<dyn Error>> {
    let mut buffer = [0; BUFFER_SIZE];
    loop {
        let bytes_read = socket.read(&mut buffer).await?;
        if bytes_read == 0 { break; }

        let start_time = Instant::now();
        if let Ok(packet) = SennexPacket::parse_raw_stream(&buffer[..bytes_read]) {
            let duration = start_time.elapsed();
            println!(
                "[SENNEX] Verified Packet ID: {} | Latency: {:?}",
                packet.packet_id, duration
            );
        }
        socket.write_all(&buffer[..bytes_read]).await?;
    }
    Ok(())
}

// ---- 5. Local Cluster Simulation Engine ----
async fn run_local_simulation() -> Result<(), Box<dyn Error>> {
    // 1. Spin up the background receiver node asynchronously
    let listener = TcpListener::bind(NODE_ADDRESS).await?;
    tokio::spawn(async move {
        if let Ok((socket, _)) = listener.accept().await {
            let _ = handle_peer_stream(socket).await;
        }
    });

    // 2. Establish connection as a simulated client peer
    tokio::time::sleep(tokio::time::Duration::from_millis(100)).await;
    let mut client = TcpStream::connect(NODE_ADDRESS).await?;

    // 3. Construct an optimized binary data payload inside stack memory
    let mut mock_packet = Vec::new();
    mock_packet.extend_from_slice(MAGIC_BYTES);
    mock_packet.extend_from_slice(&5001u32.to_be_bytes()); // Packet ID: 5001
    mock_packet.extend_from_slice(&12u32.to_be_bytes());   // Payload Size: 12 Bytes
    mock_packet.extend_from_slice(b"ALADDIN_CORE");        // Raw Macro Data

    // 4. Inject payload into the simulation network pipeline
    println!("[SENNEX SIMULATION] Injecting 1024-byte aligned data frame into runtime...");
    client.write_all(&mock_packet).await?;

    // 5. Catch response from simulation server
    let mut response_buffer = [0; BUFFER_SIZE];
    let _ = client.read(&mut response_buffer).await?;
    println!("[SENNEX SIMULATION] Local Cluster Validation Completed Successfully.");

    Ok(())
}
